    "pako": "^2.1.0",
    "portless": "^0.13.0",
    "postcss": "^8.5.3",
    "postgres": "^3.4.8",
    "shadcn": "latest",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
