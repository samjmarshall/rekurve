{
  "name": "rekurve",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "biome check . && tsc --noEmit",
    "dev": "concurrently -k -n rekurve,inngest -c blue,green \"yarn dev:rekurve\" \"yarn dev:inngest\"",
    "dev:rekurve": "portless run --force ./scripts/dev-rekurve.sh",
    "dev:inngest": "portless run --force --name inngest.rekurve ./scripts/dev-inngest.sh",
    "format:check": "biome format .",
    "format:write": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "preview": "next build && next start",
    "preview:inngest": "inngest dev -u http://localhost:3000/api/inngest",
    "porless:get": "portless get",
    "start": "next start",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:features": "playwright test e2e/features/",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:journeys": "playwright test e2e/journeys/",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:e2e:report": "playwright show-report",
    "test:e2e:tablet": "playwright test --project=tablet",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "test": "rstest run",
    "test:watch": "rstest watch",
    "test:integration": "rstest run integration.test",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "posthog:setup": "tsx scripts/posthog-setup.ts",
    "postinstall": "husky",
    "release": "auto shipit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.97.1",
    "@azure/msal-node": "5.1.5",
    "@base-ui/react": "1.4.1",
    "@hookform/resolvers": "5.2.2",
