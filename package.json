    "better-auth": "1.6.11",
    "class-variance-authority": "0.7.1",
    "client-only": "0.0.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "framer-motion": "12.38.0",
    "inngest": "4.2.6",
    "input-otp": "1.4.2",
