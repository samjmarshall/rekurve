{
  "name": "www",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "eslint . && tsc --noEmit",
    "check:e2e": "playwright test --reporter=list",
    "dev": "next dev --turbo",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "preview": "next build && next start",
    "start": "next start",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:desktop": "playwright test --project=desktop",
    "test:e2e:features": "playwright test e2e/features/",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:journeys": "playwright test e2e/journeys/",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:e2e:report": "playwright show-report",
    "test:e2e:tablet": "playwright test --project=tablet",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "posthog:setup": "tsx scripts/posthog-setup.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@posthog/nextjs-config": "^1.6.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.3",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tsparticles/engine": "^3.9.1",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "lucide-react": "^0.553.0",
    "motion": "^12.23.24",
    "next": "16.0.10",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.298.0",
    "posthog-node": "^5.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-fast-marquee": "^1.6.5",
    "react-hook-form": "^7.66.0",
    "react-rough-notation": "^1.0.8",
    "tailwind-merge": "^3.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/pako": "^2.0.4",
    "@types/react": "19.2.8",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.181.0",
    "baseline-browser-mapping": "^2.9.15",
    "eslint": "^9.23.0",
    "eslint-config-next": "16.0.10",
    "pako": "^2.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "shadcn": "latest",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  },
  "ct3aMetadata": {
    "initVersion": "7.39.3"
  },
