{
  "enableAllProjectMcpServers": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{event:\"invoke\",ts:(now|todate),session_id:.session_id,skill:.tool_input.skill,args:(.tool_input.args // null)}' >> \"$CLAUDE_PROJECT_DIR/.claude/skills.log\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/skill-logger.py\"",
            "timeout": 30,
            "async": true
          }
        ]
      }
    ]
  }
}