  "devDependencies": {
    "@auto-it/conventional-commits": "^11.3.6",
    "@auto-it/git-tag": "^11.3.6",
    "@auto-it/released": "^11.3.6",
    "@biomejs/biome": "^2.4.9",
    "@faker-js/faker": "^9",
    "@opentelemetry/api": "^1.9.1",
